name: CI - Test

on:
  pull_request:
    branches:
      - main
      - master

jobs:
  test:
    name: Test with pnpm
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: pnpm
          package-manager: pnpm

      - name: Install pnpm (ensures executable exists)
        uses: pnpm/action-setup@v2
        with:
          version: latest

      - name: Check pnpm version
        run: pnpm --version

      - name: Install dependencies
        run: pnpm install

      - name: Run tests
        run: pnpm test -- --watchAll=false
